# ─── Node / TypeScript ────────────────────────────────────────────────────────
node_modules/
# dist/scripts/ is committed (plugin distribution per ADR-010 Q1, enforced by
# .husky/pre-commit). Only dist/tests/ stays ignored — it's compiled test
# artifacts that have no production use.
dist/tests/
# tsc --incremental output (local-only, machine-specific)
*.tsbuildinfo
# Vitest / nyc coverage output
coverage/
.nyc_output/

# ─── Python (plan-020 — harness supports .py consumer projects) ───────────────
# Bytecode + Python tool caches (generated when hook tests run py_compile,
# or when a consumer project runs mypy/pytest/ruff against their own code)
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
# Coverage (pytest-cov / coverage.py)
.coverage
.coverage.*
htmlcov/
# Packaging artifacts
*.egg-info/
*.egg
# Virtual environments (user-local; never commit)
.venv/
venv/
env/

# ─── Tooling / OS / Editors ───────────────────────────────────────────────────
.husky/_/
.DS_Store
Thumbs.db
.idea/
*.log

# ─── Secrets / databases ──────────────────────────────────────────────────────
.env
.env.*
*.db
*.db-journal

# ─── Claude Code personal state (per Claude Code best practice) ───────────────
.claude.local.md
.claude/agent-memory/
.claude/settings.local.json

# ─── Personal productivity notes (not for plugin distribution) ────────────────
docs/insights/
