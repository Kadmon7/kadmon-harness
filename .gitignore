# ─── Node / TypeScript ────────────────────────────────────────────────────────
node_modules/
# dist/scripts/ is committed (plugin distribution per ADR-010 Q1, enforced by
# .husky/pre-commit). Only dist/tests/ stays ignored — it's compiled test
# artifacts that have no production use.
dist/tests/
# tsc --incremental output (local-only, machine-specific)
*.tsbuildinfo
# Vitest / nyc coverage output
coverage/
.nyc_output/

# ─── Python (plan-020 — harness supports .py consumer projects) ───────────────
# Bytecode + Python tool caches (generated when hook tests run py_compile,
# or when a consumer project runs mypy/pytest/ruff against their own code)
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
# Coverage (pytest-cov / coverage.py)
.coverage
.coverage.*
htmlcov/
# Packaging artifacts
*.egg-info/
*.egg
# Virtual environments (user-local; never commit)
.venv/
venv/
env/

# ─── Tooling / OS / Editors ───────────────────────────────────────────────────
.husky/_/
.DS_Store
Thumbs.db
.idea/
*.log

# ─── Secrets / databases ──────────────────────────────────────────────────────
.env
.env.*
*.db
*.db-journal

# ─── Claude Code personal state (per Claude Code best practice) ───────────────
.claude.local.md
.claude/agent-memory/
.claude/settings.local.json

# ─── Personal productivity notes (not for plugin distribution) ────────────────
docs/insights/

# ─── graphify — external knowledge-graph layer (ADR-026) ──────────────────────
# Keep graph.json, GRAPH_REPORT.md, graph.html committable (team workflow).
# Skip local-only heavy or machine-specific artifacts per upstream README.
graphify-out/cache/
graphify-out/manifest.json
graphify-out/cost.json
# Obsidian vault: 883 regenerable visualization notes (re-build from graph.json via to_obsidian).
# Human-facing only; Claude reads graph.json + wiki/, not the vault (ADR-026 + research-007).
graphify-out/obsidian/
# Ephemeral Q&A memory from graphify save-result (re-accrues on next runs).
graphify-out/memory/
