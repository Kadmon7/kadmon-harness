        "env": {
          "KADMON_RUNTIME_ROOT": "${CLAUDE_PLUGIN_DATA}"
        },
        "matcher": "Edit|Write"
      },
      {
        "name": "observe-post",
        "command": "${HOOK_CMD_PREFIX} ${CLAUDE_PLUGIN_ROOT}/.claude/hooks/scripts/observe-post.js",
        "env": {
          "KADMON_RUNTIME_ROOT": "${CLAUDE_PLUGIN_DATA}"
        }
      }
