          "KADMON_RUNTIME_ROOT": "${CLAUDE_PLUGIN_DATA}"
        },
        "matcher": "Bash"
      },
      {
        "name": "commit-format-guard",
        "command": "${HOOK_CMD_PREFIX} ${CLAUDE_PLUGIN_ROOT}/.claude/hooks/scripts/commit-format-guard.js",
        "env": {
          "KADMON_RUNTIME_ROOT": "${CLAUDE_PLUGIN_DATA}"
        },
        "matcher": "Bash"
      },
