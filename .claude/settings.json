{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(/c/Users/kadmo/.ssh/**)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*:*)",
      "Bash(> .env:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/block-no-verify.js"
          },
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/git-push-reminder.js"
          },
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/commit-format-guard.js"
          },
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/commit-quality.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/config-protection.js"
          },
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/no-context-guard.js"
          }
        ]
      },
      {
        "matcher": "mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/mcp-health-check.js"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/observe-pre.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/pr-created.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/post-edit-format.js"
          },
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/post-edit-typecheck.js"
          },
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/quality-gate.js"
          },
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/ts-review-reminder.js"
          },
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/console-log-warn.js"
          },
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/deps-change-reminder.js"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/observe-post.js"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/mcp-health-failure.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/pre-compact-save.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/session-start.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PATH=\"$PATH:/c/Program Files/nodejs\" node .claude/hooks/scripts/session-end-all.js"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  }
}
